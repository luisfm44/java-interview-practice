{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: compilar",
      "type": "shell",
      "command": "./scripts/mvn-java21.sh compile -q",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": {
        "owner": "java",
        "fileLocation": ["absolute"],
        "pattern": {
          "regexp": "^\\[ERROR\\] (.+):\\[(\\d+),(\\d+)\\] (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    }
  ]
}
